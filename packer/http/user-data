#cloud-config
autoinstall:
  version: 1
  locale: en_US
  keyboard:
    layout: en
  ssh:
    install-server: true
    allow-pw: true
    disable_root: true
    ssh_quiet_keygen: true
    allow_public_ssh_keys: true
  packages:
    - qemu-guest-agent
    - sudo

  late-commands:
  - curtin in-target -- systemctl enable qemu-guest-agent
  - curtin in-target -- systemctl start qemu-guest-agent
  - curtin in-target -- apt-get install -y cloud-init=23.4.2-1ubuntu0~22.04.1

  storage:
    layout:
      name: direct
    swap:
      size: 0
  
user-data:
  package_upgrade: false
  timezone: America/New_York
  users:
    - name: ubuntu
      groups: [adm, sudo]
      lock-passwd: false
      sudo: ALL=(ALL) NOPASSWD:ALL
      shell: /bin/bash
      # passwd: your-password
      # - or -
      ssh_authorized_keys:
        - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINICfGyjRaIAJvIQd5ggsHalOeBPHQSi5rsqa4CdhPQm passwordless dimarcode login"